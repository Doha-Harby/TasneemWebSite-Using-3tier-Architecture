@using Tass_BLL.ViewModes.Patient
@model List<GetAllActivePatientsVM>

@{
    ViewData["Title"] = @SharedLocalizer["AllPatients"];
}
@section Styles {
    <link rel="stylesheet" href="~/css/GetAll.css" asp-append-version="true" />
}
@section Scripts {
    <link rel="stylesheet" href="~/js/GetAll.js" asp-append-version="true" />
}

<div class="container mt-4" dir="rtl">
    <!-- رأس الصفحة -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="">
            <i class="fas fa-users me-2"></i>@SharedLocalizer["AllPatients"]
        </h2>
        <a asp-controller="Patient" asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus me-1"></i>@SharedLocalizer["AddNewPatient"]
        </a>
    </div>

    <!-- بطاقات الإحصائيات السريعة -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white mb-3" style="background: linear-gradient(135deg, #1b9d5f 0%, #0f6e42 100%);">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">@SharedLocalizer["AllPatients"]</h6>
                        <h3 class="mb-0">@Model.Count</h3>
                    </div>
                    <i class="fas fa-user-md fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- شريط البحث -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control" placeholder=@SharedLocalizer["SearchWithName"] onkeyup="searchTable()">
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select" id="filterSelect" onchange="filterTable()">
                        <option value="all"> @SharedLocalizer["AllPatients"]</option>
                        <option value="hasMeasurements">@SharedLocalizer["WithMeasurements"] </option>
                        <option value="noMeasurements">@SharedLocalizer["WithoutMeasurements"]</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- جدول المرضى -->
    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle" id="patientsTable">
                    <thead class="table-primary">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">
                                <i class="fas fa-user me-1"></i>@SharedLocalizer["Name"]
                            </th>
                            <th scope="col">
                                <i class="fas fa-calendar me-1"></i>@SharedLocalizer["Age"]
                            </th>
                            <th scope="col">
                                <i class="fas fa-phone me-1"></i>@SharedLocalizer["Job"]
                            </th>
                            <th scope="col">
                                <i class="fas fa-ruler me-1"></i>@SharedLocalizer["Hight"]
                            </th>
                            <th scope="col">
                                <i class="fas fa-arrow-up me-1"></i>@SharedLocalizer["Diagnosis"]
                            </th>
                            <th scope="col">
                                <i class="fas fa-list-ul me-1"></i> @SharedLocalizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var patient in Model)
                        {
                            <tr>
                                <th scope="row">@(counter++)</th>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <strong>@patient.Name</strong>
                                    </div>
                                </td>
                                <td>@patient.Job</td>
                                <td>
                                    <span class="badge bg-info rounded-pill">@patient.Hight @SharedLocalizer["cm"]</span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary rounded-pill">@patient.Age @SharedLocalizer["year"]</span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">@patient.Diagnosis</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="PatientDetails" asp-route-id="@patient.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           data-bs-toggle="tooltip"
                                           title=@SharedLocalizer["Details"]>
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="PatientDetails" asp-route-id="@patient.Id" asp-route-editMode="true"
                                           class="btn btn-sm btn-outline-warning" title=@SharedLocalizer["Edit"]>
                                            <i class="fas fa-edit me-1"></i>
                                        </a>
                                        <a asp-action="PrintPatient" asp-route-id="@patient.Id"
                                           class="btn btn-primary btn-sm me-2" target="_blank" title=@SharedLocalizer["Prints"]>
                                            <i class="fas fa-print me-1"></i>
                                        </a>
                                        <form asp-action="SoftDelete" asp-route-id="@patient.Id" method="post" style="display:inline;">
                                            <button type="submit"
                                                    class="btn btn-danger btn-sm me-2"
                                                    title=@SharedLocalizer["SoftDelete"]
                                                    onclick="return confirm();">
                                                <i class="fas fa-trash-alt me-1"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                                   
                            </tr>
                        }
     
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

