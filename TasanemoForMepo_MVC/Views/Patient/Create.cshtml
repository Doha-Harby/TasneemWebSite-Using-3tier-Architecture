@using Tass_BLL.ViewModes.Patient
@model CreatePatientVM
@{
    ViewData["Title"] = "إضافة مريض جديد";
}
@section Styles { 
    <link rel="stylesheet" href="~/css/CreatePatient.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="info-card">
                <div class="card-header-custom">
                    <h4 class="mb-0">
                        <i class="fas fa-user-plus me-2"></i>
                        إضافة مريض جديد
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group-custom">
                                    <label asp-for="Name"></label>
                                    <input asp-for="Name" class="form-control-custom" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="Age"></label>
                                    <input asp-for="Age" type="number" class="form-control-custom" />
                                    <span asp-validation-for="Age" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="Hight"></label>
                                    <input asp-for="Hight" type="number" step="0.1" class="form-control-custom" />
                                    <span asp-validation-for="Hight" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="Job"></label>
                                    <input asp-for="Job" class="form-control-custom" />
                                    <span asp-validation-for="Job" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label asp-for="Notes"></label>
                                    <input asp-for="Notes" type="text" class="form-control-custom" />
                                    <span asp-validation-for="Notes" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group-custom">
                            <label asp-for="Diagnosis"></label>
                            <input asp-for="Diagnosis" class="form-control-custom" />
                            <span asp-validation-for="Diagnosis" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn-custom">
                                <i class="fas fa-save me-2"></i>
                                حفظ المريض
                            </button>
                            <a asp-action="Index" class="btn btn-light ms-2">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
