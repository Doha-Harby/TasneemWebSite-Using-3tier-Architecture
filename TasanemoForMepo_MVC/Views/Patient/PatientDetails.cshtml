@using Tass_BLL.ViewModes.Patient
@model PatientDetailsModifyModeVM

@{
    ViewData["Title"] = Model.IsEditMode ? @SharedLocalizer["EditsPatientInformation"] : @SharedLocalizer["PatientDetails"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/CreatePatient.css" asp-append-version="true" />
     <link rel="stylesheet" href="~/css/GetAll.css" asp-append-version="true" />
}

<div class="container py-4">
    <!-- Header Section -->
    <div class="patient-header">
        <div class="row align-items-center">
            <div class="col-md-2 text-center text-md-start">
                <div class="patient-avatar">
                    <i class="fas fa-user-circle"></i>
                </div>
            </div>
            <div class="col-md-8 text-center text-md-start">
                @if (!Model.IsEditMode)
                {
                    <h2 class="mb-2">@Model.Patient.Name</h2>
                    <p class="mb-0 opacity-75">
                        <i class="fas fa-id-card me-2"></i>
                        @SharedLocalizer["PatientsNumber"]: #@Model.Patient.Id
                    </p>
                }
                else
                {
                    <h2 class="mb-2"> @SharedLocalizer["EditsPatientInformation"] </h2>
                    <p class="mb-0 opacity-75">
                        <i class="fas fa-id-card me-2"></i>
                        @SharedLocalizer["PatientsNumber"]: #@Model.Patient.Id
                    </p>
                }
            </div>
            <div class="col-md-2 text-center text-md-end mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light btn-sm">
                    <i class="fas fa-arrow-right me-1" ></i>
                    @SharedLocalizer["Back"]
                </a>
                @if (!Model.IsEditMode)
                {
                    <a asp-action="UpdatePatient" asp-route-id="@Model.Patient.Id" asp-route-editMode="true"
                       class="btn btn-warning btn-sm me-2">
                        <i class="fas fa-edit me-1"></i>
                        @SharedLocalizer["Edit"]
                    </a>
                }
                <a asp-action="PrintPatient" asp-route-id="@Model.Patient.Id"
                   class="btn btn-primary btn-sm me-2" target="_blank">
                    <i class="fas fa-print me-1"></i>
                    @SharedLocalizer["Prints"]
                </a>
            </div>
        </div>
    </div>

   
    <div class="row">
        <!-- Patient Info Section -->
        <div class="col-lg-5 mb-4">
            <div class="info-card">
                <div class="card-header-custom">
                    <h4 class="mb-0">
                        <i class="fas fa-user me-2"></i>
                        @SharedLocalizer["PatientDetails"]
                    </h4>
                </div>
                <div class="card-body">
                    @if (!Model.IsEditMode)
                    {
                        <!-- عرض المعلومات فقط -->
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-user me-2 text-primary-green"></i>
                                @SharedLocalizer["Name"]
                            </div>
                            <div class="info-value">@Model.Patient.Name</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-user-circle me-2 text-primary-green"></i>
                                @SharedLocalizer["Age"]
                            </div>
                            <div class="info-value">@Model.Patient.Age  @SharedLocalizer["year"]</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-ruler me-2 text-primary-green"></i>
                                @SharedLocalizer["Hight"]
                            </div>
                            <div class="info-value">@Model.Patient.Hight  @SharedLocalizer["cm"]</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-briefcase me-2 text-primary-green"></i>
                                @SharedLocalizer["Job"]
                            </div>
                            <div class="info-value">@Model.Patient.Job</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-stethoscope me-2 text-primary-green"></i>
                                @SharedLocalizer["Diagnosis"]
                            </div>
                            <div class="info-value">
                                <span class="badge-custom">@Model.Patient.Diagnosis</span>
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-note-sticky me-2 text-primary-green"></i>
                                @SharedLocalizer["Notes"]
                            </div>
                            <div class="info-value">
                                @Model.Patient.Notes
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">
                                <i class="fas fa-clock me-2 text-primary-green"></i>
                                @SharedLocalizer["Date"]
                            </div>
                            <div class="info-value">@Model.Patient.CreatedOn.ToString("dd MMMM yyyy")</div>
                        </div>
                    }
                    else
                    {
                        <!-- نموذج التعديل -->
                        <form asp-controller ="Patient" asp-action="UpdatePatient" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Patient.Id" />

                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Name" class="form-label">
                                    <i class="fas fa-user me-2 text-primary-green"></i>
                                    @SharedLocalizer["Name"]
                                </label>
                                <input asp-for="Patient.Name" class="form-control-custom" required />
                                <span asp-validation-for="Patient.Name" class="text-danger"></span>
                            </div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Age" class="form-label">
                                    <i class="fas fa-user-circle me-2 text-primary-green"></i>
                                    @SharedLocalizer["Age"]
                                </label>
                                <input asp-for="Patient.Age" type="number" class="form-control-custom" />
                                <span asp-validation-for="Patient.Age" class="text-danger"></span>
                            </div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Hight" class="form-label">
                                    <i class="fas fa-ruler me-2 text-primary-green"></i>
                                    @SharedLocalizer["Hight"]
                                </label>
                                <input asp-for="Patient.Hight" type="number" step="0.01" class="form-control-custom" />
                                <span asp-validation-for="Patient.Hight" class="text-danger"></span>
                            </div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Job" class="form-label">
                                    <i class="fas fa-briefcase me-2 text-primary-green"></i>
                                    @SharedLocalizer["Job"]
                                </label>
                                <input asp-for="Patient.Job" class="form-control-custom" />
                                <span asp-validation-for="Patient.Job" class="text-danger"></span>
                            </div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Diagnosis" class="form-label">
                                    <i class="fas fa-stethoscope me-2 text-primary-green"></i>
                                    @SharedLocalizer["Diagnosis"]
                                </label>
                                <input asp-for="Patient.Diagnosis" class="form-control-custom" />
                                <span asp-validation-for="Patient.Diagnosis" class="text-danger"></span>
                            </div>

                            <div class="form-group-custom mb-3">
                                <label asp-for="Patient.Notes" class="form-label">
                                    <i class="fas fa-note-sticky me-2 text-primary-green"></i>
                                    @SharedLocalizer["Notes"]
                                </label>
                                <textarea asp-for="Patient.Notes" class="form-control-custom" rows="3"></textarea>
                                <span asp-validation-for="Patient.Notes" class="text-danger"></span>
                            </div>

                            <div class="mt-4">
                                <button type="submit" class="btn-custom">
                                    <i class="fas fa-save me-2"></i>
                                    @SharedLocalizer["SaveChanges"]
                                </button>
                                <a asp-action="PatientDetails" asp-route-id="@Model.Patient.Id" class="btn btn-secondary ms-2">
                                    <i class="fas fa-times me-2"></i>
                                    @SharedLocalizer["Cancel"]
                                </a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <!-- Add Measurement Section (يبقى كما هو) -->
        <div class="col-lg-7 mb-4">
            <div class="info-card">
                <div class="card-header-custom">
                    <h4 class="mb-0">
                        <i class="fas fa-chart-simple me-2"></i>
                        @SharedLocalizer["AddNewMeasurement"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-controller="Measurement" asp-action="AddMeasurement" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PatientId" value="@Model.Patient.Id" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label>@SharedLocalizer["Chest"] (@SharedLocalizer["cm"])</label>
                                    <input name="Chest" type="number" step="0.1" min="0" max="900" class="form-control-custom" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label>@SharedLocalizer["UpperAbdomen"]  (@SharedLocalizer["cm"])</label>
                                    <input name="UpperAbdomen" type="number" step="0.1" min="0" max="900" class="form-control-custom" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label>@SharedLocalizer["LowerAbdomen"]  (@SharedLocalizer["cm"])</label>
                                    <input name="LowerAbdomen" type="number" step="0.1" min="0" max="900" class="form-control-custom" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label> @SharedLocalizer["Buttocks"] (@SharedLocalizer["cm"])</label>
                                    <input name="Buttocks" type="number" step="0.1" min="0" max="900" class="form-control-custom" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label>@SharedLocalizer["MeasurementDate"]</label>
                                    <input name="MeasurementDate" type="date" class="form-control-custom" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group-custom">
                                    <label> @SharedLocalizer["Weight"] (@SharedLocalizer["kg"])</label>
                                    <input name="Weight" type="number" step="0.1" min="0" max="900" class="form-control-custom" />
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn-custom">
                            <i class="fas fa-save me-2"></i>
                            @SharedLocalizer["SaveMeasurement"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Measurements History Section  -->
    <div class="row">
        <div class="col-12">
            <div class="info-card">
                <div class="card-header-custom">
                    <h4 class="mb-0">
                        <i class="fas fa-history me-2"></i>    
                        @Model.Measurements.Count @SharedLocalizer["TotalMeasurements"]
                    </h4>
                    
                </div>
                <div class="card-body">
                    @if (Model.Measurements.Any())
                    {
                        <div class="table-responsive">
                            <table class="measurement-table table table-hover">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-calendar"></i> @SharedLocalizer["Date"]</th>
                                        <th><i class="fas fa-weight-scale"></i> @SharedLocalizer["Weight"]</th>
                                        <th><i class="fas fa-heart"></i> @SharedLocalizer["Chest"]</th>
                                        <th><i class="fas fa-arrow-up"></i>@SharedLocalizer["UpperAbdomen"]</th>
                                        <th><i class="fas fa-arrow-down"></i> @SharedLocalizer["LowerAbdomen"]</th>
                                        <th><i class="fas fa-people-arrows"></i> @SharedLocalizer["Buttocks"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var measurement in Model.Measurements.OrderByDescending(m => m.MeasurementDate))
                                    {
                                        <tr>
                                            <td class="fw-bold">@measurement.MeasurementDate.ToString("dd/MM/yyyy")</td>
                                            <td>@measurement.Weight @SharedLocalizer["kg"]</td>
                                            <td>@measurement.Chest @SharedLocalizer["cm"]</td>
                                            <td>@measurement.UpperAbdomen  @SharedLocalizer["cm"]</td>
                                            <td>@measurement.LowerAbdomen  @SharedLocalizer["cm"]</td>
                                            <td>@measurement.Buttocks  @SharedLocalizer["cm"]</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-chart-line"></i>
                            <h5 class="mt-3">
                                @SharedLocalizer["NoMeasurementsWereRecorded"]
                            </h5>
                            <p class="text-muted">@SharedLocalizer["AddThePatient'sFirstMeasurementUsingTheAdjacentForm"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}