@using Tass_BLL.ViewModes.Patient
@model PrintPatientDetailsVM
@{
    Layout = null;
    ViewData["Title"] = $" {@SharedLocalizer["Follow-upReport"]} - {Model.Patient.Name}";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/PrintPatient.css" asp-append-version="true" />
</head>
<body>
    <div class="print-wrapper">
        <!-- أزرار التحكم -->
        <div class="print-controls no-print">
            <button class="btn-print" onclick="window.print()">
                🖨️ @SharedLocalizer["PrintTheReport"]
            </button>
            <button class="btn-close" onclick="window.close()">
                ✖️ @SharedLocalizer["Close"]
            </button>
        </div>

        <!-- رأس التقرير -->
        <div class="print-header">
            <div class="logo-section">
                <img src="~/images/TasneemLogo.jpeg" alt="Dr. Tasneem Ahmed Harby" class="logo" />
            </div>
            <div class="doctor-info">
                <h1>Dr. Tasneem Ahmed Harby</h1>
                <p class="specialty">@SharedLocalizer["PhysicianAndClinicalNutritionist"]</p>
                <p class="num">📞 01274231990</p>
            </div>
        </div>

        <!-- معلومات المريض - في صفين -->
        <div class="patient-info-card">
            <div class="section-title">
                <span>📋</span>@SharedLocalizer["PatientDetails"]
            </div>
            <div class="info-grid two-columns">
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Name"]:</span>
                    <span class="info-value">@Model.Patient.Name</span>
                </div>
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Age"]:</span>
                    <span class="info-value">@Model.Patient.Age @SharedLocalizer["year"]</span>
                </div>
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Hight"]:</span>
                    <span class="info-value">@Model.Patient.Hight @SharedLocalizer["cm"]</span>
                </div>
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Job"]:</span>
                    <span class="info-value">@Model.Patient.Job</span>
                </div>
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Diagnosis"]:</span>
                    <span class="info-value">@Model.Patient.Diagnosis</span>
                </div>
                <div class="info-item">
                    <span class="info-label">@SharedLocalizer["Notes"]:</span>
                    <span class="info-value">@Model.Patient.Notes</span>
                </div>
            </div>
        </div>

        <!-- سجل القياسات -->
        <div class="patient-info-card">
            <div class="section-title">
                <span>📊</span> @SharedLocalizer["RecordMeasurements"]
            </div>
            @if (Model.Measurements.Any())
            {
                <div class="table-responsive">
                    <table class="measurements-table">
                        <thead>
                            <tr>
                                <th>@SharedLocalizer["Date"]</th>
                                <th>@SharedLocalizer["Weight"]</th>
                                <th>@SharedLocalizer["Chest"]</th>
                                <th>@SharedLocalizer["UpperAbdomen"]</th>
                                <th>@SharedLocalizer["LowerAbdomen"]</th>
                                <th>@SharedLocalizer["Buttocks"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.Measurements.OrderByDescending(x => x.MeasurementDate))
                            {
                                <tr>
                                    <td>@m.MeasurementDate.ToString("dd/MM/yyyy")</td>
                                    <td>@m.Weight @SharedLocalizer["kg"]</td>
                                    <td>@m.Chest @SharedLocalizer["cm"]</td>
                                    <td>@m.UpperAbdomen @SharedLocalizer["cm"]</td>
                                    <td>@m.LowerAbdomen @SharedLocalizer["cm"]</td>
                                    <td>@m.Buttocks @SharedLocalizer["cm"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="no-data">📭  @SharedLocalizer["NoMeasurementsWereRecorded"]</p>
            }
        </div>

        <!-- التخصصات -->
        <div class="specialties-grid">
            <p class="specialty">🏥 @SharedLocalizer["ObesityAndThinness"]</p>
            <p class="specialty">🤰 @SharedLocalizer["PregnancyAndBreastfeeding"]</p>
            <p class="specialty">💊 @SharedLocalizer["ChronicDiseases"]</p>
            <p class="specialty">🍎 @SharedLocalizer["Children'sNutrition"]</p>
        </div>
    </div>

    <script>
        // وظيفة الطباعة
        function handlePrint() {
            window.print();
        }

        // اكتشاف إذا كان الجهاز هاتف
        function isMobile() {
            return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        }

        // تحسين عرض الجداول على الهواتف
        if (isMobile()) {
            const tables = document.querySelectorAll('.measurements-table');
            tables.forEach(table => {
                table.style.fontSize = '12px';
                const cells = table.querySelectorAll('th, td');
                cells.forEach(cell => {
                    cell.style.padding = '6px 4px';
                });
            });
        }

        // تأثيرات عند الطباعة
        window.onbeforeprint = function() {
            document.body.classList.add('printing');
        };

        window.onafterprint = function() {
            document.body.classList.remove('printing');
        };
    </script>
</body>
</html>